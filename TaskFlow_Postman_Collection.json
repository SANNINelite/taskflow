        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Capture JWT token from response and save it automatically as a collection/environment variable",
                  "if (pm.response.code === 200) {",
                  "    var responseJson = pm.response.json();",
                  "    if (responseJson && responseJson.data && responseJson.data.token) {",
                  "        pm.globals.set(\"jwt_token\", responseJson.data.token);",
                  "        console.log(\"JWT Token captured and saved dynamically in globals!\");",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
