# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Replace with your actual local or cloud MongoDB connection string
MONGODB_URI=mongodb://127.0.0.1:27017/taskflow

# JWT Security
# Ensure this is a secure, long string in production
JWT_SECRET=your_super_secret_jwt_high_entropy_key_12345!
JWT_EXPIRES_IN=7d

# CORS Settings
# Set this to your frontend URL in production (e.g. http://localhost:5173 or Vercel URL)
CLIENT_URL=http://localhost:5173
